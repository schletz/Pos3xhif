{
  "name": "asciidoc-productivity",
  "publisher": "schletz",
  "displayName": "asciidoc-productivity",
  "description": "Improves AsciiDoc editing features.",
  "version": "1.0.1",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Die-Spengergasse/course-pos-csharp_basics"
  },

  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "AsciiDoc Productivity",
      "properties": {
        "asciidoc-productivity.includeExtensions": {
          "type": "string",
          "default": "cs|csproj|java|rb|json|js|ts|jsx|tsx|py|txt|xml|adoc|md|cmd|sh|sql|yaml|puml",
          "description": "Regex für Dateiendungen, die beim Kopieren berücksichtigt werden sollen (z.B. 'cs|csproj|ts|html')."
        },
        "asciidoc-productivity.excludeDirectories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "bin",
            "obj",
            "node_modules"
          ],
          "description": "Verzeichnisse, die beim Kopieren ignoriert werden sollen."
        },
        "asciidoc-productivity.excludeFiles": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "package-lock.json"
          ],
          "description": "Dateien, die beim Kopieren ignoriert werden sollen."
        }
      }
    },
    "commands": [
      {
        "command": "asciidoc-productivity.insertSourceBlock",
        "title": "Insert clipboard as source block"
      },
      {
        "command": "asciidoc-productivity.insertImageBlock",
        "title": "Insert image from URL"
      },
      {
        "command": "asciidoc-productivity.insertTsvTable",
        "title": "Insert clipboard as tsv table"
      },
      {
        "command": "asciidoc-productivity.insertImageFromFile",
        "title": "Insert image from file"
      },
      {
        "command": "asciidoc-productivity.insertImageFromClipboard",
        "title": "Insert image from clipboard"
      },
      {
        "command": "asciidoc-productivity.insertFileAsSourceBlock",
        "title": "Insert file as source block"
      },
      {
        "command": "asciidoc-productivity.copySourcesToClipboard",
        "title": "Copy sources to clipboard",
        "icon": "$(notebook-open-as-text)"
      },
      {
        "command": "asciidoc-productivity.copyAsTsv",
        "title": "Copy AsciiDoc Table as TSV to clipboard"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "asciidoc-productivity.copySourcesToClipboard",
          "when": "view == workbench.explorer.fileView",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "asciidoc-productivity.insertSourceBlock",
          "when": "editorLangId == asciidoc",
          "group": "navigation@1"
        },
        {
          "command": "asciidoc-productivity.insertTsvTable",
          "when": "editorLangId == asciidoc",
          "group": "navigation@2"
        },
        {
          "command": "asciidoc-productivity.insertImageBlock",
          "when": "editorLangId == asciidoc",
          "group": "navigation@3"
        },
        {
          "command": "asciidoc-productivity.insertImageFromFile",
          "when": "editorLangId == asciidoc",
          "group": "navigation@4"
        },
        {
          "command": "asciidoc-productivity.insertImageFromClipboard",
          "when": "editorLangId == asciidoc",
          "group": "navigation@5"
        },
        {
          "command": "asciidoc-productivity.copyAsTsv",
          "when": "editorLangId == asciidoc",
          "group": "navigation@6"
        }
      ],
      "explorer/context": [
        {
          "command": "asciidoc-productivity.insertFileAsSourceBlock",
          "group": "navigation"
        },
        {
          "command": "asciidoc-productivity.copySourcesToClipboard",
          "when": "explorerResourceIsFolder",
          "group": "2_workspace"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "ts-loader": "^9.5.4",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  },
  "dependencies": {
    "mammoth": "^1.12.0",
    "pdfreader": "^3.0.8"
  }
}