        <mxCell id="lxpbxQVvUjYBtnMyNS0J-18" parent="1" style="text;html=1;whiteSpace=wrap;rounded=1;arcSize=4;fillColor=#ffffff;strokeColor=#cbd5e1;strokeWidth=1;shadow=1;spacing=8;" value="&lt;div style=&quot;color: rgb(32, 32, 32); font-family: &amp;quot;Cascadia Code&amp;quot;, Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-weight: normal; font-size: 14px; line-height: 19px; white-space: pre;&quot;&gt;&lt;div&gt;&lt;span style=&quot;color: #0550ae;font-weight: bold;&quot;&gt;= Ein Titel&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #202020;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #0550ae;&quot;&gt;source-highlighter&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #0a3069;&quot;&gt; rouge&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #202020;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #0550ae;&quot;&gt;icons&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #0a3069;&quot;&gt; font&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #202020;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #0550ae;&quot;&gt;lang&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #0a3069;&quot;&gt; DE&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #202020;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #0550ae;&quot;&gt;hyphens&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;:&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #202020;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #0550ae;&quot;&gt;figure-caption!&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;:&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #8250df;&quot;&gt;ifndef&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;::env-github[&lt;/span&gt;&lt;span style=&quot;color: #0a3069;&quot;&gt;:icons: font&lt;/span&gt