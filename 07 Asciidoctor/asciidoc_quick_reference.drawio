        <mxCell id="lxpbxQVvUjYBtnMyNS0J-19" parent="1" style="text;html=1;whiteSpace=wrap;rounded=1;arcSize=4;fillColor=#ffffff;strokeColor=#cbd5e1;strokeWidth=1;shadow=1;spacing=8;" value="&lt;div style=&quot;color: rgb(32, 32, 32); font-family: &amp;quot;Cascadia Code&amp;quot;, Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-weight: normal; font-size: 14px; line-height: 19px; white-space: pre;&quot;&gt;&lt;div&gt;&lt;span style=&quot;color: #116329;&quot;&gt;extends&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;: &lt;/span&gt;&lt;span style=&quot;color: #0000ff;&quot;&gt;default&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #116329;&quot;&gt;page&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;:&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #202020;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #116329;&quot;&gt;margin&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;: [&lt;/span&gt;&lt;span style=&quot;color: #0000ff;&quot;&gt;20mm&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #0000ff;&quot;&gt;20mm&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #0000ff;&quot;&gt;20mm&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #0000ff;&quot;&gt;20mm&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;]&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #116329;&quot;&gt;heading&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;:&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #202020;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #6e7781;&quot;&gt;# h1 is used for part titles (book doctype) or the doctitle (article doctype)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #202020;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #116329;&quot;&gt;h1_font_size&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;: &lt;/span&gt;&lt;span style=&quot;color: #0000ff;&quot;&gt;floor($base_font_size_large * 2)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #202020;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #6e7781;&quot;&gt;# h2 is used for chapter titles (book doctype only)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #202020;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #116329;&quot;&gt;h2_font_size&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;: &lt;/span&gt;&lt;span style=&quot;color: #0000ff;&quot;&gt;floor($base_font_size_large * 1.59)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #202020;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #116329;&quot;&gt;h3_font_size&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;: &lt;/span&gt;&lt;span style=&quot;color: #0000ff;&quot;&gt;round($base_font_size_large * 1.26)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #202020;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #116329;&quot;&gt;h4_font_size&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;: &lt;/span&gt;&lt;span style=&quot;color: #0000ff;&quot;&gt;$base_font_size_large&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #202020;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #116329;&quot;&gt;h5_font_size&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;: &lt;/span&gt;&lt;span style=&quot;color: #0000ff;&quot;&gt;$base_font_size&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #202020;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #116329;&quot;&gt;h6_font_size&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;: &lt;/span&gt;&lt;span style=&quot;color: #0000ff;&quot;&gt;$base_font_size_small&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #116329;&quot;&gt;code&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;:&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #202020;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #116329;&quot;&gt;font_size&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;: &lt;/span&gt;&lt;span style=&quot;color: #0000ff;&quot;&gt;$base_font_size&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #202020;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #116329;&quot;&gt;line_height&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;: &lt;/span&gt;&lt;span style=&quot;color: #098658;&quot;&gt;1.15&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #116329;&quot;&gt;list&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;:&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #202020;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #116329;&quot;&gt;item_spacing&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;: &lt;/span&gt;&lt;span style=&quot;color: #0000ff;&quot;&gt;$vertical_rhythm / 6&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #116329;&quot;&gt;table&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;:&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #202020;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #116329;&quot;&gt;cell_padding&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;: &lt;/span&gt;&lt;span style=&quot;color: #098658;&quot;&gt;1.3&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #116329;&quot;&gt;quote&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;:&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #202020;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #116329;&quot;&gt;font_size&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;: &lt;/span&gt;&lt;span style=&quot;color: #0000ff;&quot;&gt;$base_font_size &amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #116329;&quot;&gt;footer&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;:&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #202020;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #116329;&quot;&gt;recto&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;:&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #202020;&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #116329;&quot;&gt;right&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;:&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #202020;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #116329;&quot;&gt;content&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;: &lt;/span&gt;&lt;span style=&quot;color: #0a3069;&quot;&gt;&quot;{page-number} von {page-count}&quot;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #202020;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #116329;&quot;&gt;verso&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;:&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #202020;&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #116329;&quot;&gt;right&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;:&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #202020;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #116329;&quot;&gt;content&lt;/span&gt;&lt;span style=&quot;color: #202020;&quot;&gt;: &lt;/span&gt;&lt;span style=&quot;color: #0a3069;&quot;&gt;&quot;{page-number} von {page-count}&quot;&lt;/span&gt;&lt;/div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
